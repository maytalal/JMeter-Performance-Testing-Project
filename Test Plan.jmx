    &quot;password&quot;: &quot;allahaman3&quot;,&#xd;
    &quot;firstName&quot;: &quot;Mai&quot;,&#xd;
    &quot;lastName&quot;: &quot;Talal&quot;&#xd;
}</stringProp>
